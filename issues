#!/usr/bin/env python3
"""Enhanced gh issue list sorted by priority labels.

Usage:
  issues                list open issues, highest priority first
  issues --mine         only issues assigned to me
  issues --limit N      limit results (default 50)
  issues --json         raw JSON from gh
  issues --help
"""
import argparse, json, subprocess, sys

# Priority order: lower index = higher priority
_PRIORITY_RANK = [
    "p0", "priority:critical",
    "p1", "priority:high", "high",
    "p2", "priority:medium", "medium",
    "p3", "priority:low", "low",
]


def extract_priority(label_names):
    lc = {l.lower() for l in label_names}
    for p in _PRIORITY_RANK:
        if p in lc:
            return p
    return ""


def _priority_sort_key(p):
    try:
        return _PRIORITY_RANK.index(p)
    except ValueError:
        return len(_PRIORITY_RANK)


def main():
    ap = argparse.ArgumentParser(description="Enhanced gh issue list.")
    ap.add_argument("--mine", action="store_true", help="Only issues assigned to me")
    ap.add_argument("--limit", type=int, default=50)
    ap.add_argument("--json", action="store_true", dest="as_json", help="Raw JSON output")
    args = ap.parse_args()

    cmd = [
        "gh", "issue", "list",
        "--json", "number,title,labels,assignees,createdAt,url",
        "--limit", str(args.limit),
    ]
    if args.mine:
        cmd += ["--assignee", "@me"]

    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)

    issues = json.loads(result.stdout)

    if args.as_json:
        print(json.dumps(issues, indent=2))
        return

    if not issues:
        print("No open issues.")
        return

    for issue in issues:
        label_names = [l.get("name", "") for l in (issue.get("labels") or [])]
        issue["_priority"] = extract_priority(label_names)
        issue["_labels"] = ", ".join(label_names)
        assignees = issue.get("assignees") or []
        issue["_assignees"] = ", ".join(a.get("login", "?") for a in assignees)

    issues.sort(key=lambda i: _priority_sort_key(i["_priority"]))

    w_num = max(len("#NUM"), len("#" + str(max(i["number"] for i in issues))) + 1)
    w_title = min(60, max(len("TITLE"), max(len(i["title"]) for i in issues)))
    w_priority = max(len("PRIORITY"), max(len(i["_priority"]) for i in issues))
    w_labels = min(35, max(len("LABELS"), max(len(i["_labels"]) for i in issues)))

    def row(num, title, priority, labels, assignees):
        return (
            f"{num:<{w_num}}  "
            f"{title:<{w_title}}  "
            f"{priority:<{w_priority}}  "
            f"{labels:<{w_labels}}  "
            f"{assignees}"
        )

    header = row("#", "TITLE", "PRIORITY", "LABELS", "ASSIGNEES")
    print(header)
    print("-" * len(header))
    for issue in issues:
        print(
            row(
                f"#{issue['number']}",
                issue["title"][:w_title],
                issue["_priority"],
                issue["_labels"][:w_labels],
                issue["_assignees"],
            )
        )


if __name__ == "__main__":
    main()
